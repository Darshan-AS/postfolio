{
    "firestore": {
        "rules": "firestore.rules"
    },
    "hosting": {
        "maxInstances": 5,
        "public": "build/web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "emulators": {
        "auth": {
            "port": 9099
        },
        "firestore": {
            "port": 8080
        },
        "ui": {
            "enabled": true
        },
        "singleProjectMode": false
    },
    "flutter": {
        "platforms": {
            "android": {
                "default": {
                    "projectId": "postfolio-app",
                    "appId": "1:143378829514:android:92a750e6c503288d20a433",
                    "fileOutput": "android/app/google-services.json"
                }
            },
            "ios": {
                "default": {
                    "projectId": "postfolio-app",
                    "appId": "1:143378829514:ios:73e9955c243c868720a433",
                    "uploadDebugSymbols": false,
                    "fileOutput": "ios/Runner/GoogleService-Info.plist"
                }
            },
            "macos": {
                "default": {
                    "projectId": "postfolio-app",
                    "appId": "1:143378829514:ios:73e9955c243c868720a433",
                    "uploadDebugSymbols": false,
                    "fileOutput": "macos/Runner/GoogleService-Info.plist"
                }
            },
            "dart": {
                "lib/firebase_options.dart": {
                    "projectId": "postfolio-app",
                    "configurations": {
                        "android": "1:143378829514:android:92a750e6c503288d20a433",
                        "ios": "1:143378829514:ios:73e9955c243c868720a433",
                        "macos": "1:143378829514:ios:73e9955c243c868720a433",
                        "web": "1:143378829514:web:07d791d58b39110420a433",
                        "windows": "1:143378829514:web:ada2f101378be46220a433"
                    }
                }
            }
        }
    }
}
