rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure the user's specific data silo
    match /users/{userId} {
      
      // Allow a user to read and write ONLY if their Auth Token UID matches the userId in the path
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Cascade this rule to all subcollections (customers, one_time_deposits, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
