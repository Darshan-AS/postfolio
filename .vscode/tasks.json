{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Firebase Emulators",
            "type": "shell",
            "command": "firebase emulators:start",
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^.*$",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Starting emulators",
                    "endsPattern": "All emulators ready!"
                }
            },
            "runOptions": {
                "instanceLimit": 1,
                "reevaluateOnRerun": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
